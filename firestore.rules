rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == 'admin';
    }

    function isStaff() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (getUserData().role == 'staff' || getUserData().role == 'admin');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Products
    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() && isValidId(productId);
      
      // Allow stock updates by staff through sales
      allow update: if isStaff() && incoming().diff(existing()).affectedKeys().hasOnly(['quantity', 'updatedAt']);
    }

    // Sales
    match /sales/{saleId} {
      allow read: if isStaff();
      allow create: if isStaff() && isValidId(saleId) && 
                    incoming().staffId == request.auth.uid &&
                    incoming().createdAt == request.time;
      allow update, delete: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && (
        (incoming().role == 'admin' && request.auth.token.email == 'benedictpas01@gmail.com') ||
        (incoming().role == 'staff')
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
