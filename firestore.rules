rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com' ||
        request.auth.token.email == 'director@aldapas.com' ||
        request.auth.token.email == 'benedictpas01@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isVerified() && (
        (request.auth.token.email == 'benedictpas01@gmail.com' || request.auth.token.email == 'director@aldapas.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    function isStaff() {
      return isVerified() && (
        (request.auth.token.email == 'benedictpas01@gmail.com' || request.auth.token.email == 'director@aldapas.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserData().role == 'staff' || getUserData().role == 'admin'))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collections ---

    // Settings
    match /settings/{settingId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Products
    match /products/{productId} {
      allow read: if isStaff();
      allow create, delete: if isAdmin() && isValidId(productId);
      
      // Allow stock updates by staff (through sales processing)
      allow update: if isStaff() && (
        isAdmin() || 
        incoming().diff(existing()).affectedKeys().hasOnly(['quantity', 'updatedAt'])
      );
    }

    // Sales
    match /sales/{saleId} {
      // Secure List Query Enforcement
      allow read: if isStaff() && (
        isAdmin() || resource.data.staffId == request.auth.uid
      );
      
      allow create: if isStaff() && isValidId(saleId) && 
                    incoming().staffId == request.auth.uid &&
                    incoming().createdAt == request.time;
                    
      allow update, delete: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      allow create: if isSignedIn() && request.auth.uid == userId && (
        // Restrict first admins to specific emails
        (incoming().role == 'admin' && (
          request.auth.token.email == 'benedictpas01@gmail.com' || 
          request.auth.token.email == 'director@aldapas.com'
        )) ||
        (incoming().role == 'staff')
      );
      
      allow update: if isAdmin() && (
        // Prevent admins from changing their own role to ensure at least one admin exists
        (request.auth.uid != userId) || (incoming().role == 'admin')
      );
      
      allow delete: if isAdmin() && request.auth.uid != userId;
    }
  }
}
